{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run with QGIS Python",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "python": "/Applications/QGIS.app/Contents/MacOS/python",
      "console": "integratedTerminal"
    },
    {
      "name": "Split route features",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/python/split_route_features.py",
      "python": "/Applications/QGIS.app/Contents/MacOS/python",
      "console": "integratedTerminal"
    },
    {
      "name": "Export routes to GPX",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/python/export_routes_to_gpx.py",
      "python": "/Applications/QGIS.app/Contents/MacOS/python",
      "console": "integratedTerminal"
    }
  ]
}
